<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Chat</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="form-container">

        <h2>✏️ Edit Chat</h2>

        <p class="info">
            From <b><%= chat.from %></b> → To <b><%= chat.to %></b>
        </p>

        <form method="POST" action="/chats/<%= chat._id %>?_method=PUT">
            
            <textarea name="msg"><%= chat.msg %></textarea>
            <br/><br/>

            <button type="submit" class="edit-btn">Update Message</button>

        </form>

        <br/>
        <a href="/chats" class="back-link">← Back to Chats</a>

    </div>

</body>
</html>